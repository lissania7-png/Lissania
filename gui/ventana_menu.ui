/* Barra de menú */
QMenuBar {
    background-color: #1e1e1e;
    color: #e0e0e0;
    font-size: 18px;
    padding: 5px;
}

QMenuBar::item {
    background: transparent;
    padding: 5px 15px;
}

QMenuBar::item:selected {
