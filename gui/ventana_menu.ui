    color: #ffffff;
}

/* Menús */
QMenu {
    background-color: #1a1a1a;
    color: #e0e0e0;
    border: 1px solid #8b0000;
    font-size: 18px;
}

QMenu::item {
    padding: 8px 20px;
}

QMenu::item:selected {
    background-color: #b22222;
    color: #ffffff;
}
</string>
