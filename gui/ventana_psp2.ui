  <property name="styleSheet">
   <string notr="true">QDialog, QWidget {
    background-color: #000000; /* negro */
}

/* QLabel */
QLabel {
    color: #FFD700;
    font-weight: bold;
    font-size: 36pt;
}

/* Botones gaming */
QPushButton {
    background-color: #48b9dbff;
    color: #FFD700;
    border: 2px solid #FFD700;
    border-radius: 10px;
    padding: 8px 16px;
    font-weight: bold;
}
/* QLineEdit estilo gaming */
QLineEdit {
    background-color: #5e81f5ff; /* negro con tono rojizo */
    color: #FFD700; /* texto dorado */
    border: 2px solid #477dbbff; /* rojo oscuro */
    border-radius: 8px;
    padding: 6px;
    selection-background-color: #6cdaa3ff; /* cuando seleccionas texto */
    selection-color: #FFD700;
}

/* Cuando el usuario hace clic */
QLineEdit:focus {
    border: 2px solid #FFD700; /* borde dorado brillante */
    background-color: #94eca2ff;
}

/* Hover */
QLineEdit:hover {
    border: 2px solid #7adfacff;
}

/* Placeholder (texto guía) */
QLineEdit::placeholder {
    color: #f8c4c4ff; /* rojizo tenue */
}
QPushButton:hover {
    background-color: #39659eff;
}

QPushButton:pressed {
    background-color: #005504ff;
}</string>
